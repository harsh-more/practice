// Handle browser back/forward navigation
window.addEventListener('popstate', function(event) {
    // Check if file editor is open and has unsaved changes
    if ($('.edit-view').is(':visible')) {
        var editHasNotBeenMade = editor.session.getUndoManager().isClean();
        if (!editHasNotBeenMade) {
            var confirmLeave = confirm("You have unsaved changes. Do you really want to leave?");
            if (!confirmLeave) {
                // User wants to stay - restore the previous URL without triggering popstate
                history.pushState(null, null, currentUrlState);
                return;
            }
            // User confirmed to leave - close editor
            editor.setValue('');
            statusbar.reset();
            $(".edit-view").css('display', 'none');
            $("#containerFileManager").css('display', 'block');
            removeAllToasts();
        } else {
            // No unsaved changes - close editor normally
            if ($('.edit-view').is(':visible')) {
                editor.setValue('');
                statusbar.reset();
                $(".edit-view").css('display', 'none');
                $("#containerFileManager").css('display', 'block');
                removeAllToasts();
            }
        }
    }
    
    // Update current URL state for future navigation blocking
    currentUrlState = window.location.href;
    
    // Get the current path from the URL
    var currentPath = window.location.pathname;
    var fileManagerBasePath = '/newui/filemanager/';
    
    if (currentPath.startsWith(fileManagerBasePath)) {
        var pathParam = currentPath.substring(fileManagerBasePath.length);
        pathParam = pathParam.trim().split('/').filter(segment => segment !== '').join('/');

        if (!pathParam) {
            // If no path parameter, load root directory
            displayFileManagerView('', true, false);
            return;
        }

        // Check if it's a file or directory by making a HEAD request
        fetch(`/api/vfs/${pathParam}`, {
            method: 'HEAD',
            redirect: 'manual'  // This prevents automatic redirect following
        }).then(function(response) {            
            if (response.status === 307 || response.type === 'opaqueredirect') {
                // redirect or opaque redirect means it's a directory (needs trailing slash)
                displayFileManagerView(pathParam, true, false);
            } else if (response.status === 200) {
                // 200 means it's a file
                displayFileManagerView(pathParam, true, true);
            } else if (response.status === 404) {
                // 404 means path doesn't exist
                displayFileManagerView(pathParam, false, false);
            } else {
                // Other status codes
                displayFileManagerView(pathParam, false, false, true);
            }
        }).catch(function(error) {
            displayFileManagerView(pathParam, false, false);
        });
    }
});

// Handle beforeunload to prevent navigation away from unsaved changes
window.addEventListener('beforeunload', function(event) {
    if ($('.edit-view').is(':visible')) {
        var editHasNotBeenMade = editor.session.getUndoManager().isClean();
        if (!editHasNotBeenMade) {
            // Prevent navigation and show browser's confirmation dialog
            event.preventDefault();
            event.returnValue = 'You have unsaved changes. Do you really want to leave?';
            return event.returnValue;
        }
    }
});